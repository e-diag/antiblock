# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID_1=your_telegram_user_id
# Чат для отчётов /ops_* и стартового сообщения после деплоя (команды компенсации и миграции прокси).
# Также сюда уходят критические алерты (health free/premium, недоступность прокси), если задан этот ID.
# Если TELEGRAM_MANAGER_PROGRESS_CHAT_ID пуст — алерты шлются в TELEGRAM_ERROR_LOG_CHAT_ID (см. config.yaml / env).
# Бот должен быть участником чата. ID группы/супергруппы обычно отрицательный (-100...).
# Если пусто — то же текстом в личку всем TELEGRAM_ADMIN_ID_*.
# TELEGRAM_MANAGER_PROGRESS_CHAT_ID=

# Метка контура в HTML-отчётах миграции из бота (по умолчанию bot).
# OPS_CONTOUR=prod-docker
# Пауза между шагами /ops_proxy_migrate (сек, по умолчанию 30). Один шаг = один пользователь/Pro-группа.
# OPS_MIGRATE_STEP_DELAY_SEC=45
# Доп. менеджеры (нужны и в .env, и в docker-compose environment — см. TELEGRAM_ADMIN_ID_2..5 в compose)
TELEGRAM_ADMIN_ID_2=
# Или список через запятую: TELEGRAM_ADMIN_IDS=111,222,333
# TELEGRAM_ADMIN_IDS=

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=antiblock
DB_SSLMODE=disable
DB_TIMEZONE=UTC

# CryptoBot API Configuration (устарело, можно не заполнять)
CRYPTOBOT_API_TOKEN=
CRYPTOBOT_WEBHOOK_SECRET=

# ЮКасса (Smart Payment API)
YOOKASSA_PROVIDER_TOKEN=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://example.com/return
YOOKASSA_WEBHOOK_PORT=8082
# Опциональный shared secret для webhook endpoint (header: X-AntiBlock-Webhook-Token).
# Рекомендуется задавать в production.
YOOKASSA_WEBHOOK_TOKEN=

# xRocket Pay API Configuration (TON)
XROCKET_API_TOKEN=your_xrocket_api_token
XROCKET_API_URL=https://pay.xrocket.tg
XROCKET_WEBHOOK_PORT=8081
XROCKET_WEBHOOK_SECRET=your_xrocket_webhook_secret

# Pro-сервер (Free + Pro + legacy Premium cleanup): в config.yaml блок pro_docker (host, cert_path, server_ip).

# Мониторинг: docker compose -f docker-compose.monitoring.yml up -d
# GRAFANA_PASSWORD=admin

# TimeWeb — новые Premium (floating IP + SSH ключ). Без токена новые покупки ждут настройки.
TIMEWEB_API_TOKEN=
TIMEWEB_AVAILABILITY_ZONE=spb-3
TIMEWEB_SSH_USER=root

# ID SSH-ключа бота в TimeWeb (получить через /setup_ssh_key upload в боте).
TIMEWEB_SSH_KEY_ID=0

# Путь к приватному ключу внутри контейнера (монтируется через PREMIUM_KEYS_PATH).
TIMEWEB_SSH_KEY_PATH=/antiblock/premium-keys/premium_bot_key

# Явный os_id ОС для Premium VPS (пусто = авто Ubuntu 24.04 из /api/v1/os/servers).
# TIMEWEB_PREMIUM_OS_ID=
# Мин. секунд между SSH-операциями к одному Premium VPS (0 = без паузы; в config.yaml есть default).
# TIMEWEB_PREMIUM_SSH_MIN_INTERVAL_SEC=40

# Папка с SSH-ключами бота на хосте (premium_bot_key + premium_bot_key.pub).
PREMIUM_KEYS_PATH=./premium-keys
