# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID_1=your_telegram_user_id

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=antiblock
DB_SSLMODE=disable
DB_TIMEZONE=UTC

# CryptoBot API Configuration (устарело, можно не заполнять)
CRYPTOBOT_API_TOKEN=
CRYPTOBOT_WEBHOOK_SECRET=

# xRocket Pay API Configuration (USDT)
XROCKET_API_TOKEN=your_xrocket_api_token
XROCKET_API_URL=https://pay.xrocket.tg
XROCKET_WEBHOOK_PORT=8081
XROCKET_WEBHOOK_SECRET=your_xrocket_webhook_secret

# Путь к папке с сертификатами Docker TLS (ca.pem, cert.pem, key.pem) для подключения к премиум-серверу.
# Пробрасывается в контейнер бота как /antiblock/docker-certs (только чтение). По умолчанию: ./docker-certs
# DOCKER_CERTS_PATH=./docker-certs
